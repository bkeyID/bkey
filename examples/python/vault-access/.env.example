# Copy to .env and fill in. Do not commit .env.
#
# Create agent credentials once:
#   npm install -g @bkey/cli
#   bkey auth login
#   bkey auth setup-agent --name "Vault Demo" --save
#
# Store a test secret (one-time — triggers Face ID on your phone):
#   bkey vault store openai-api-key --field value=sk-test-...

BKEY_CLIENT_ID=
BKEY_CLIENT_SECRET=
BKEY_USER_DID=did:bkey:...

# Optional — defaults to https://api.bkey.id
# BKEY_API_URL=https://api.bkey.id
