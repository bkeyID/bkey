# BKey API base URL. Use https://api.bkey.id for production.
BKEY_API_URL=https://api.bkey.id

# OAuth client credentials for this agent.
# Register an agent client at https://bkey.id and paste the values here.
BKEY_CLIENT_ID=
BKEY_CLIENT_SECRET=

# The DID of the user who will receive the biometric checkout prompt.
# Format: did:bkey:...
# Find yours in the BKey mobile app under Settings → Developer.
BKEY_USER_DID=

# Merchant identity shown on the user's phone during approval.
# In a real deployment these are your merchant's production values — the
# customer sees the name + domain before approving a charge.
MERCHANT_NAME=Acme Coffee
MERCHANT_DOMAIN=acme-coffee.example

# Where the merchant expects the approved checkout session to be finalized.
# Included in the approval payload so the user can see where their money
# is going. BKey calls back to this URL after biometric approval to
# complete the order (for demo purposes the example merchant is fake).
MERCHANT_CHECKOUT_URL=https://acme-coffee.example/checkout/bkey
