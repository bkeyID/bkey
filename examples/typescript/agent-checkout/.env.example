# Copy to .env and fill in. Do not commit .env.
#
# Create agent credentials once:
#   npm install -g @bkey/cli
#   bkey auth login
#   bkey auth setup-agent --name "Checkout Demo" --save

BKEY_CLIENT_ID=
BKEY_CLIENT_SECRET=

# BKey DID of the user whose approval is required.
# Find it in the BKey mobile app: Settings → Developer → Copy DID.
BKEY_USER_DID=did:bkey:...

# Optional — defaults to https://api.bkey.id
# BKEY_API_URL=https://api.bkey.id
