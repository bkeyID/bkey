# BKey API base URL. Use https://api.bkey.id for production.
BKEY_API_URL=https://api.bkey.id

# OAuth client credentials for this vault-access agent.
# Register an agent client at https://bkey.id and paste the values here.
BKEY_CLIENT_ID=
BKEY_CLIENT_SECRET=

# The DID of the user who owns the vault and will receive biometric
# approval prompts on their phone.
# Format: did:bkey:...
# Find yours in the BKey mobile app under Settings → Developer.
BKEY_USER_DID=
