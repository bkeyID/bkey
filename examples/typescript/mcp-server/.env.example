# BKey API base URL. Use https://api.bkey.id for production.
BKEY_API_URL=https://api.bkey.id

# Issuer used for JWKS discovery and `iss` claim check.
# Should match BKEY_API_URL in most cases.
BKEY_ISSUER=https://api.bkey.id

# OAuth client credentials for this MCP server.
# Register an agent client at https://bkey.id and paste the values here.
BKEY_CLIENT_ID=
BKEY_CLIENT_SECRET=

# The DID of the user who will receive biometric approval prompts.
# Format: did:bkey:...
# Find yours in the BKey mobile app under Settings → Developer.
BKEY_USER_DID=

# Scope that approval tokens must carry.
# The MCP server requests this scope from BKey and also verifies it on the
# returned token. Keep it tight — one scope per sensitive action.
BKEY_APPROVAL_SCOPE=approve:deploy
