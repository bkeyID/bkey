{
  "name": "@bkey/cli",
  "version": "0.2.0",
  "description": "BKey CLI — secure credential proxy and biometric approval for AI agents",
  "type": "module",
  "bin": {
    "bkey": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "prebuild": "bash scripts/gen-build-info.sh",
    "build": "tsc",
    "predev": "bash scripts/gen-build-info.sh",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "clean": "rm -rf dist"
  },
  "dependencies": {
