    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@types/node": "^22.13.0",
    "@types/qrcode": "^1.5.6",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/bkeyID/bkey.git",
    "directory": "typescript/packages/cli"
  },
  "license": "Apache-2.0",
  "keywords": ["bkey", "cli", "biometric", "ciba", "oauth", "agent"]
